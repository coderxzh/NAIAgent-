{
  "name": "nai-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "build": "npm run build:web && npm run build:electron",
    "build:web": "vite build",
    "build:electron": "npm run build:main && npm run build:preload",
    "build:main": "esbuild electron/main.ts --bundle --platform=node --target=node22 --format=cjs --external:electron --external:better-sqlite3 --outfile=dist-electron/main/main.cjs",
    "build:preload": "esbuild electron/preload.ts --bundle --platform=node --target=node22 --format=cjs --external:electron --outfile=dist-electron/preload/preload.js",
    "preview": "vite preview",
    "electron": "ELECTRON_RUN_AS_NODE= electron dist-electron/main/main.cjs",
    "pack": "ELECTRON_RUN_AS_NODE= electron-builder --dir",
    "dist": "ELECTRON_RUN_AS_NODE= electron-builder",
    "dist:mac": "ELECTRON_RUN_AS_NODE= electron-builder --mac",
    "dist:win": "ELECTRON_RUN_AS_NODE= electron-builder --win",
    "dist:linux": "ELECTRON_RUN_AS_NODE= electron-builder --linux",
    "postinstall": "electron-rebuild",
    "clean": "rm -rf dist dist-electron release",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^2.4.0",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.6",
    "@langchain/openai": "^1.5.3",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@rive-app/react-webgl2": "^4.29.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.11.0",
    "ai": "^6.0.208",
    "ansi-to-react": "^6.2.6",
    "apexcharts": "^5.15.2",
    "better-sqlite3": "^12.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "deepagents": "^1.10.5",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "media-chrome": "^4.19.2",
    "motion": "^12.40.0",
    "nanoid": "^5.1.15",
    "pdf-parse": "^1.1.1",
    "radix-ui": "^1.6.0",
    "react": "^19.0.1",
    "react-apexcharts": "^2.1.1",
    "react-dom": "^19.0.1",
    "react-jsx-parser": "^2.4.1",
    "shadcn": "^4.11.0",
    "shiki": "^4.2.0",
    "sqlite-vec": "^0.1.6",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/xlsx": "^0.0.35",
    "autoprefixer": "^10.4.21",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "allowScripts": {
    "electron@35.7.5": true
  }
}
