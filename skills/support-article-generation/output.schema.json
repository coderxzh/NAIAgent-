{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["title", "content", "confidence"],
  "properties": {
    "title": {
      "type": "string",
      "description": "文章标题"
    },
    "content": {
      "type": "string",
      "description": "完整 Markdown 文章内容"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "模型对文章内容基于证据的信心评分"
    }
  },
  "additionalProperties": false
}
